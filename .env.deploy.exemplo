# Variáveis do docker-compose.yml (opcional — os defaults já batem com este servidor).
# Copie para .env NA RAIZ só se precisar sobrescrever algo.
#
# Padrão confirmado em srv1291961 (mesmo do aureon): rede proxy, entrypoints web/websecure,
# certresolver le. Com esses defaults, você NÃO precisa de .env aqui — só do backend/.env.producao.

TRAEFIK_NETWORK=proxy
DOMAIN=h4c.codexaurora.com.br
ENTRYPOINT=websecure
ENTRYPOINT_HTTP=web
CERT_RESOLVER=le
