# Variáveis lidas pelo docker-compose.yml no deploy (copie para .env NA RAIZ do projeto).
# Ajuste conforme o padrão do Traefik do servidor (veja um projeto vizinho em /srv/stack).

# Nome da REDE externa que o Traefik usa (ex.: traefik, proxy, web).
# Descubra com:  docker network ls | grep -i traefik
TRAEFIK_NET=traefik

# Nome do certresolver Let's Encrypt configurado no Traefik (ex.: le, letsencrypt, myresolver).
# Descubra com:  grep -ri certresolver /srv/stack/traefik
CERT_RESOLVER=le
